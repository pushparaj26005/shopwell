{
    "version": 2,
    "buildCommand": "sh build_files.sh",
    "builds": [
        {
            "src": "rms/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "rms/wsgi.py"
        }
    ],
    "env": {
        "DEBUG": "False",
        "VERCEL": "1"
    }
}